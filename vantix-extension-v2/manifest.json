{
  "manifest_version": 3,
  "name": "Vantix — Sensitive Data Guard",
  "version": "2.0.2",
  "description": "Detects and blocks sensitive data typed into AI tools. Connects to your company backend for custom rules.",

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "permissions": [
    "activeTab",
    "storage",
    "identity"
  ],

  "host_permissions": [
    "http://127.0.0.1:5000/*",
    "http://localhost:5000/*",
    "https://accounts.google.com/*",
    "https://github.com/*",
    "https://*.firebaseapp.com/*",
    "https://*.googleapis.com/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "externally_connectable": {
    "matches": ["http://localhost:5173/*"]
  },

  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://*.openai.com/*",
        "https://*.google.com/*",
        "https://claude.ai/*",
        "https://copilot.microsoft.com/*",
        "https://www.perplexity.ai/*",
        "https://chat.deepseek.com/*",
        "https://grok.com/*",
        "https://www.meta.ai/*",
        "https://huggingface.co/chat/*",
        "https://chat.mistral.ai/*"
      ],
      "js": [
        "services/api.js",
        "utils/redactor.js",
        "detector.js",
        "content.js"
      ],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ]
}
